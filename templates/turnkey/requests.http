@apiBaseUrl = http://localhost:8000
@healthPath = /health
@sessionPath = /api/session
@protectedSmokePath = /api/<replace-me-resource>
@authToken = <replace-me-bearer-token-or-remove-header>

### Health check
GET {{apiBaseUrl}}{{healthPath}}

### Session or auth-state check
GET {{apiBaseUrl}}{{sessionPath}}

### Protected smoke check
GET {{apiBaseUrl}}{{protectedSmokePath}}
Authorization: Bearer {{authToken}}

### OpenAPI document
GET {{apiBaseUrl}}/openapi.json
