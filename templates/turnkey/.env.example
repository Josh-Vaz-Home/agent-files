# Non-secret local defaults for the strict turnkey profile.
# Replace hostnames, project identifiers, and addresses for the adopted repository.

APP_ENV=development
FRONTEND_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
OPENAPI_URL=http://localhost:8000/openapi.json
PLAYWRIGHT_BASE_URL=http://localhost:4173

# Choose one: ui-login | api-assisted | storage-state
PLAYWRIGHT_AUTH_MODE=ui-login

E2E_ADMIN_EMAIL=admin@example.com
E2E_MEMBER_EMAIL=member@example.com

AUTH_ISSUER=https://auth.example.com/application/o/<replace-me>
AUTH_AUDIENCE=<replace-me-audience>

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_test

SONAR_HOST_URL=https://sonarcloud.io
SONAR_ORGANIZATION=<replace-me-org>
SONAR_PROJECT_KEY=<replace-me-project-key>

REVIEW_BASE_REF=origin/main
